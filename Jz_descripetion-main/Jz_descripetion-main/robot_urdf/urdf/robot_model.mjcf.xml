<mujoco model="dual_arm_robot">
    <compiler angle="radian" meshdir="../meshes/"/>

    <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast" iterations="100" solver="Newton" tolerance="1e-8"/>

    <visual>
        <global offwidth="1920" offheight="1080"/>
        <quality shadowsize="4096"/>
    </visual>

    <default>
        <joint armature="10" damping="100" limited="true" frictionloss="1"/>
        <geom condim="4" friction="1 0.5 0.5" margin="0.001"/>
        <default class="visual_geom">
            <geom contype="0" conaffinity="0"/>
        </default>
        <default class="collision_geom">
            <geom group="3" rgba="1 1 1 0"/>
        </default>
        <motor ctrllimited="true" ctrlrange="-500 500"/>
    </default>

