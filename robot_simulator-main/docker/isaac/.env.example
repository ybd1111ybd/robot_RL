# Copy to .env and adjust paths for the target machine.

# Isaac Sim 5.1.0 container image.
ISAAC_SIM_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0

# Local training image built from the Isaac Sim image with Isaac Lab/RL deps.
ISAAC_LAB_IMAGE=jz-isaaclab:5.1.0
ISAAC_LAB_VERSION=2.3.2.post1

# Host paths.
ROBOT_SIMULATOR_ROOT=/home/cqy/workspace/middle_platform/robot_simulator/robot_simulator-main
JZ_DESCRIPTION_ROOT=/home/cqy/workspace/middle_platform/robot_simulator/Jz_descripetion-main/Jz_descripetion-main

# Optional Isaac Lab / RL task workspace. Leave as an existing empty directory
# until your jz_isaac_lab or RL_jzrobot project is available.
JZ_ISAAC_LAB_ROOT=/home/cqy/workspace/middle_platform/robot_simulator/jz_isaac_lab

# Container paths. Keep these stable so scripts and configs are portable.
CONTAINER_WORKSPACE=/workspace

# Isaac Sim 5.1.0 container runs as a rootless user in NVIDIA's official docs.
ISAAC_CONTAINER_UID=1234
ISAAC_CONTAINER_GID=1234

# Persistent Isaac Sim cache/config/log directories on the host.
ISAAC_CACHE_ROOT=/home/cqy/docker/isaac-sim-5.1

# NVIDIA / rendering settings.
ACCEPT_EULA=Y
PRIVACY_CONSENT=Y
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
